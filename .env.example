# HoverPay SMS Gateway Environment Credentials
# -------------------------------------------------------------
# Copy this file to .env.local for local development.
# For Netlify deployment, add these environment variables in your Netlify Dashboard.
# 
# NOTE: Next.js static exports compile env variables prefixed with 
# NEXT_PUBLIC_ directly into the static JS files at build-time. 
# This allows secure, client-side REST dispatch to Twilio.

NEXT_PUBLIC_TWILIO_SID=
NEXT_PUBLIC_TWILIO_AUTH_TOKEN=
NEXT_PUBLIC_TWILIO_FROM_NUMBER=
